<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="GCOverlay" parent="">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowFullscreen">true</item>
    </style>
    <style name="GCHardOverlay" parent="">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:layout_gravity">0x11</item>
        <item name="android:windowFullscreen">true</item>
    </style>
    <style name="GCAlert" parent="">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>
    <style name="MessengerButton" parent="">
        <item name="android:clickable">true</item>
    </style>
    <style name="MessengerButton.Blue" parent="@style/MessengerButton">
        <item name="android:background">@drawable/messenger_button_blue_bg_selector</item>
    </style>
    <style name="MessengerButton.Blue.Large" parent="@style/MessengerButton.Blue">
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_marginLeft">16dp</item>
        <item name="android:layout_marginRight">16dp</item>
    </style>
    <style name="MessengerButton.Blue.Small" parent="@style/MessengerButton.Blue">
        <item name="android:layout_width">158dp</item>
        <item name="android:layout_height">36dp</item>
    </style>
    <style name="MessengerButton.White" parent="@style/MessengerButton">
        <item name="android:background">@drawable/messenger_button_white_bg_selector</item>
    </style>
    <style name="MessengerButton.White.Large" parent="@style/MessengerButton.White">
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_marginLeft">16dp</item>
        <item name="android:layout_marginRight">16dp</item>
    </style>
    <style name="MessengerButton.White.Small" parent="@style/MessengerButton.White">
        <item name="android:layout_width">158dp</item>
        <item name="android:layout_height">36dp</item>
    </style>
    <style name="MessengerButtonText" parent="">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">0x1</item>
        <item name="android:gravity">0x11</item>
        <item name="android:layout_gravity">0x11</item>
        <item name="android:layout_width">-2</item>
        <item name="android:layout_height">-2</item>
        <item name="android:drawablePadding">4dp</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <style name="MessengerButtonText.Blue" parent="@style/MessengerButtonText">
        <item name="android:textColor">#ffffff</item>
    </style>
    <style name="MessengerButtonText.Blue.Large" parent="@style/MessengerButtonText.Blue">
        <item name="android:drawableLeft">@drawable/messenger_bubble_large_white</item>
    </style>
    <style name="MessengerButtonText.Blue.Small" parent="@style/MessengerButtonText.Blue">
        <item name="android:drawableLeft">@drawable/messenger_bubble_small_white</item>
    </style>
    <style name="MessengerButtonText.White" parent="@style/MessengerButtonText">
        <item name="android:textColor">#0084ff</item>
    </style>
    <style name="MessengerButtonText.White.Large" parent="@style/MessengerButtonText.White">
        <item name="android:drawableLeft">@drawable/messenger_bubble_large_blue</item>
    </style>
    <style name="MessengerButtonText.White.Small" parent="@style/MessengerButtonText.White">
        <item name="android:drawableLeft">@drawable/messenger_bubble_small_blue</item>
    </style>
    <style name="com_facebook_auth_dialog" parent="@android:style/Theme.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>
    <style name="com_facebook_button" parent="@android:style/Widget.Button">
        <item name="android:textSize">14dp</item>
        <item name="android:textColor">@color/com_facebook_button_text_color</item>
        <item name="android:gravity">0x11</item>
        <item name="android:background">@drawable/com_facebook_button_background</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingRight">8dp</item>
        <item name="android:paddingBottom">5dp</item>
        <item name="android:drawablePadding">6dp</item>
    </style>
    <style name="com_facebook_button_like" parent="@style/com_facebook_button">
        <item name="android:background">@drawable/com_facebook_button_like_background</item>
    </style>
    <style name="com_facebook_button_send" parent="@style/com_facebook_button">
        <item name="android:textColor">@color/com_facebook_send_button_text_color</item>
        <item name="android:background">@drawable/com_facebook_button_send_background</item>
        <item name="android:text">@string/com_facebook_send_button_text</item>
        <item name="android:drawableLeft">@drawable/com_facebook_send_button_icon</item>
    </style>
    <style name="com_facebook_button_share" parent="@style/com_facebook_button">
        <item name="android:text">@string/com_facebook_share_button_text</item>
        <item name="android:drawableLeft">@drawable/com_facebook_button_icon</item>
    </style>
    <style name="com_facebook_loginview_default_style" parent="@style/com_facebook_button">
        <item name="android:drawableLeft">@drawable/com_facebook_button_icon</item>
    </style>
    <style name="com_facebook_loginview_silver_style" parent="@style/com_facebook_loginview_default_style">
        <item name="android:textColor">#4b5164</item>
        <item name="android:background">@drawable/com_facebook_button_login_silver_background</item>
        <item name="android:drawableLeft">@null</item>
    </style>
    <style name="tooltip_bubble_text" parent="">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:gravity">0x3</item>
        <item name="android:shadowColor">#40000000</item>
        <item name="android:shadowDy">-1</item>
        <item name="android:shadowRadius">0.25</item>
    </style>
    <style name="CardView" parent="@style/Base.CardView">
    </style>
    <style name="Base.CardView" parent="@android:style/Widget">
        <item name="cardCornerRadius">@dimen/cardview_default_radius</item>
        <item name="cardElevation">@dimen/cardview_default_elevation</item>
        <item name="cardMaxElevation">@dimen/cardview_default_elevation</item>
        <item name="cardUseCompatPadding">false</item>
        <item name="cardPreventCornerOverlap">true</item>
    </style>
    <style name="CardView.Dark" parent="@style/CardView">
        <item name="cardBackgroundColor">@color/cardview_dark_background</item>
    </style>
    <style name="CardView.Light" parent="@style/CardView">
        <item name="cardBackgroundColor">@color/cardview_light_background</item>
    </style>
    <style name="UnityThemeSelector" parent="@android:style/Theme.Light.NoTitleBar.Fullscreen">
    </style>
</resources>
